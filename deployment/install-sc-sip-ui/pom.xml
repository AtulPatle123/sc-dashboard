<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>com.schneiderelectric.dces.sip</groupId>
    <artifactId>sc-sip-ui-parent</artifactId>
    <version>1.2.0</version>
  </parent>

  <!-- Note that this file will be filtered during archetype packaging -->
  <!-- If you want to defnie a variable in the target pom.xml file, esace the dolllar char by '\', otherwise Var will be substitute. -->
  <groupId>com.schneiderelectric.dces.sip</groupId>
  <artifactId>install-sc-sip-ui</artifactId>
  <packaging>pom</packaging>

  <properties>
    <timestamp>${maven.build.timestamp}</timestamp>
    <maven.build.timestamp.format>yyyy-MM-dd HH:mm</maven.build.timestamp.format>
    <project.build.binary_archive>Selector-Information-Portal</project.build.binary_archive>
    <project.build.doc_archive>sc-sip-ui-doc-${project.version}</project.build.doc_archive>
    <project.build.source_archive>sc-sip-ui-sources-${project.version}</project.build.source_archive>
    <!-- This link is used in order to complet the application release notes. Edit it if the repository used is not dces -->
    <artifactory.base.dir>https://jfrog-euw.se.com/artifactory/em-dces-selectconfig-release-maven-fed/</artifactory.base.dir>
    <maven.deploy.skip>false</maven.deploy.skip>
  </properties>

  <dependencies>
    <dependency>
      <groupId>com.schneiderelectric.dces.tool</groupId>
      <artifactId>install-tool-scripts</artifactId>
      <version>1.9.33</version>
      <type>tar.gz</type>
    </dependency>
    <!-- Add here dependencies to current project binaries -->

    <dependency>
      <groupId>${project.groupId}</groupId>
      <artifactId>sc-sip-ui</artifactId>
      <version>${project.version}</version>
      <type>zip</type>
    </dependency>

  </dependencies>

  <!--
    Requirement on parent pom to e'nsure proper build and relese mgmt.
    * Maven parent pom defined the SCM Url within /project/scm/ tag
    * Maven parent pom must defined a property named project.scm.id
      For BitBucket DCES_CI account, id is usually : bitbucket-ci
      For RDITS CI account, id is usually : rdits-ci
    * Maven global settgins (in file ~/.m2/settings.xml) must defined a server credentials for property named project.scm.id
    * Maven must properly declare Distribution URL and access
    * Maven parent pom must defined the Distribution Url within /project/distributionManagement/ tag
    * Maven global settings (in file ~/.m2/settings.xml) must defined a server credentials for distribution repository
    * Maven parent pom must set of scm value to avoid scm plugin old issue via :
      build/pluginManagement/plugins/plugin : org.apache.maven.plugins:maven-scm-plugin:1.9.4, with dependencies/dependency : org.apache.maven.scm:maven-scm-provider-gitexe:1.9.4
      build/pluginManagement/plugins/plugin : org.apache.maven.plugins:maven-release-plugin:2.5.2, with dependencies/dependency : org.apache.maven.scm:maven-scm-provider-gitexe:1.9.4
                                                                                                   with configuration.localCheckout = true
                                                                                                   with autoVersionSubmodules = true
    * Maven parent include severals repositories
      pace-repository          : release  : http://10.155.34.21:8081/artifactory/websdk-release-local
      pace-snapshot-repository : snapshot : http://10.155.34.21:8081/artifactory/websdk-snapshot-local
      dces-repository          : release  : http://10.155.34.21:8081/artifactory/dces-release-local
      dces-snapshot-repository : snapshot : http://10.155.34.21:8081/artifactory/dces-snapshot-local
      central: all : http://repo1.maven.org/maven2
  -->

  <build>
    <plugins>

      <!-- Offer pugin to configure the project -->
      <plugin>
        <groupId>org.codehaus.gmaven</groupId>
        <artifactId>groovy-maven-plugin</artifactId>
        <executions>
          <execution>
            <id>configure_install_project</id>
            <goals>
              <goal>execute</goal>
            </goals>
            <configuration>
              <scriptpath>
                 <path>${basedir}/src/main/groovy</path>
              </scriptpath>
              <source>def scip = new script_configure_install_project("${basedir}") ;</source>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <!-- Generate Httpd Certificates via openssl-->
      <plugin>
         <artifactId>maven-antrun-plugin</artifactId>
         <version>1.7</version>
         <executions>
            <execution>
               <id>generate-httpd-certificates</id>
               <goals>
                  <goal>run</goal>
               </goals>
               <configuration>
                  <!--target name="generate-httpd-certificates">
                     <echo>Generate Certificate Key with fake password</echo>
                     <exec executable="cmd" dir="${project.basedir}/src/main/resources/httpd_files/certificates/" osfamily="windows" failonerror="true">
                        <arg line="/c openssl genrsa -aes256 -passout pass:xxxxxxxxxx -out sc-dashboard-ui.server.key 2048 -noout" />
                     </exec>

                     <exec executable="openssl" dir="${project.basedir}/src/main/resources/httpd_files/certificates/" osfamily="unix" failonerror="true">
                        <arg line="genrsa -aes256 -passout pass:xxxxxxxxxx -out sc-dashboard-ui.server.key 2048 -noout" />
                     </exec>

                     <echo>Removing fake password to Certificate Key</echo>
                     <exec executable="cmd" dir="${project.basedir}/src/main/resources/httpd_files/certificates/" osfamily="windows" failonerror="true">
                        <arg line="/c openssl rsa -in sc-dashboard-ui.server.key -passin pass:xxxxxxxxxx -out sc-dashboard-ui.server.key" />
                     </exec>
                     <exec executable="openssl" dir="${project.basedir}/src/main/resources/httpd_files/certificates/" osfamily="unix" failonerror="true">
                        <arg line="rsa -in sc-dashboard-ui.server.key -passin pass:xxxxxxxxxx -out sc-dashboard-ui.server.key " />
                     </exec>

                     <echo>Generate Certificate Server Request</echo>
                     <exec executable="cmd" dir="${project.basedir}/src/main/resources/httpd_files/certificates/" osfamily="windows" failonerror="true">
                        <arg line="/c openssl req -new -key sc-dashboard-ui.server.key -outsc-dashboard-ui.server.csr -subj '/C=FR/ST=Hauts de Seine/L=Rueil Malmaison/O=Schneider Electric Industries SAS/OU=DCE/CN=sc-dashboard-ui.autosigned.dces.schneider-electric.cn/emailAddress=global.dnsadmin@eud.schneider-electric.com'" />
                     </exec>
                     <exec executable="openssl" dir="${project.basedir}/src/main/resources/httpd_files/certificates/" osfamily="unix" failonerror="true">
                        <arg line="req -new -key sc-dashboard-ui.server.key -out sc-dashboard-ui.server.csr -subj '/C=FR/ST=Hauts de Seine/L=Rueil Malmaison/O=Schneider Electric Industries SAS/OU=DCE/CN=sc-dashboard-ui.autosigned.dces.schneider-electric.cn/emailAddress=global.dnsadmin@eud.schneider-electric.com' " />
                     </exec>

