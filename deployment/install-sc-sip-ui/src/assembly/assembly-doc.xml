<assembly xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2 http://maven.apache.org/xsd/assembly-1.1.2.xsd">
   <id>doc</id>
   <includeBaseDirectory>false</includeBaseDirectory>
   <formats>
      <format>tar.gz</format>
   </formats>
   <files>
      <file>
         <source>${basedir}/src/site/readme.md</source>
         <outputDirectory>/sc-sip-ui-doc-${versionWithoutSnapshotSuffix}</outputDirectory>
         <filtered>true</filtered>
      </file>
   </files>
   <fileSets>
      <fileSet>
         <directory>${basedir}/target/site/</directory>
         <outputDirectory>/sc-sip-ui-doc-${versionWithoutSnapshotSuffix}/html/</outputDirectory>
         <lineEnding>unix</lineEnding>
         <fileMode>0755</fileMode>
         <includes>
            <include>**/*</include>
         </includes>
      </fileSet>
      <fileSet>
         <directory>${basedir}/src/site/pdf</directory>
         <outputDirectory>/sc-sip-ui-doc-${versionWithoutSnapshotSuffix}/pdf</outputDirectory>
         <lineEnding>unix</lineEnding>
         <fileMode>0755</fileMode>
         <includes>
            <include>**/*</include>
         </includes>
      </fileSet>
   </fileSets>
   
</assembly>
