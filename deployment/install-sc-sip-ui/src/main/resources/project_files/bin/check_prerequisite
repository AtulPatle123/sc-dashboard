#!/bin/sh
################################################################################
#
#         FILE: project_files/bin/check_prerequsite
#
#        USAGE: project_files/bin/check_prerequsite {-continue|--continue} {-ignore-checks|--ignore-checks}
#
#  DESCRIPTION: This file execute pre-requisite test prior any action are done on sevrer
#
#               This script relies and load local files ./setenv that must contains vars for Project PROJECT_NAME for env ENV.
#               This script relies on project_files/bin/functions and script/*
#
#      OPTIONS:
#               -nocontinue           : facultative : stop on error
#               -ignore-checks        : facultative : don't return with error code when error found
#
#        NOTES:
#
#       AUTHOR: Serge Reboul
#     DIVISION: Building & IT Business (former Partner Business)
#      COMPANY: Schneider-Electric
#===============================================================================

export HAS_ERROR=0
export HAS_WARNING=0
export NO_COLOR=0

export CONTINUE=-continue
export IGNORE_CHECKS=
for var in "$@"
do
    if [[ ( "$var" == "-no-color" ) || ( "$var" == "--no-color" ) ]]; then
      export NO_COLOR="-no-color"
    fi
    if [[ ( "$var" == "-nocontinue" ) || ( "$var" == "--nocontinue" ) ]]; then
      export CONTINUE="-nocontinue"
    fi
    if [[ ( "$var" == "-ignore-checks" ) || ( "$var" == "--ignore-checks" ) ]]; then
      export IGNORE_CHECKS="-ignore-checks"
    fi
done

#-------------------------------------------------------------------------------
# Load env and functions
CURRENT_DIR=`pwd`
BASEDIR=$(dirname ${BASH_SOURCE[0]})
. ${BASEDIR}/check_functions
assert_zero $? "Impossible to load ${BASEDIR}/check_functions"

setenv
assert_zero $? "Impossible to load env variables."

if [ -z "${PROJECT_HOME}" ]; then
    error "Environment variable (PROJECT_HOME) is not defined. It should be defined within properties files in /conf."
fi

#-------------------------------------------------------------------------------
# Common Test applicable for every Installation

log "Checking global pre-requisite"


# * `aws` Yum packages are installed on the server.
check_command_in_path aws
error_if_not_zero $?

# * `jar` can be executed on sevrer .
check_command_in_path "jar"
error_if_not_zero $?

# * `nc` Yum packages are installed on the server.
check_command_in_path nc
error_if_not_zero $?

# * `wget` Yum packages are installed on the server.
check_command_in_path wget
error_if_not_zero $?

# * `wget` command, executed on behalf `${USER_NAME}` account, can access internet web site.
# check_http_get_ok https://mvnrepository.com/
# error_if_not_zero $?

#-------------------------------------------------------------------------------
# end of Checks

display_check_status
exit_if_not_zero $?
