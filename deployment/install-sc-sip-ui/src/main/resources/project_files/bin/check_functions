################################################################################
#  SECTION : SETENV FUNCTION 
################################################################################
#=== FUNCTION ================================================================
# NAME: setenv
# DESCRIPTION: load env variable located ./setenv 
#=============================================================================
function setenv()
{
   BASEDIR=$(dirname ${BASH_SOURCE[0]})
   if [ -f ${BASEDIR}/setenv ]; then
      . ${BASEDIR}/setenv
   fi
   
   if [ -f ${BASEDIR}/setenv ]; then
      log "Loading Env file ${BASEDIR}/setenv"  
      . ${BASEDIR}/setenv
   elif [ "${PROPERTIES_ALL_FILE}" != "" -a ! -f "${PROPERTIES_ALL_FILE}" ]; then
      log "Loading Env file ${PROPERTIES_ALL_FILE}"
      chmod +x ${PROPERTIES_ALL_FILE}
      . ${PROPERTIES_ALL_FILE}
   fi 
   
   if [ -z "${PROJECT_HOME}" ]; then
      error "Environment variable (PROJECT_HOME) is not defined. It should be defined within env properties files."
   fi
}

################################################################################
#  SECTION : LOGGING FUNCTION 
################################################################################

#=== FUNCTION ================================================================
# NAME: log
# DESCRIPTION: Display log message unless 1st arguement is "-nolog"
#=============================================================================
function log() {
   if [ "$1" != "-nolog" ]; then
      echo $*
   fi
}

#=== FUNCTION ================================================================
# NAME: error
# DESCRIPTION: raise an error, aka display error message and exit with response code  1
#=============================================================================
function error(){
   if [ "$1" == "-nolog" ]; then
      shift
   fi 
   echo "########################################################################"
   echo "# Error : $*"
   echo "########################################################################"
   exit 1
}

#=== FUNCTION ================================================================
# NAME: success
# DESCRIPTION: display test success with Color tabulars
#=============================================================================
function success() {
   echo -n $" - $*"
   if [[ "${NO_COLOR}" != "-no-color" ]]; then
      echo -en "\\033[120G"
      echo -en "\\033[1;32m"
   fi
   echo $" [  OK  ]"
   if [[ "${NO_COLOR}" != "-no-color" ]]; then
      echo -en "\\033[0;39m"
   fi
   return 0
}

#=== FUNCTION ================================================================
# NAME: failure
# DESCRIPTION: display test failure with Color tabulars
#=============================================================================
function failure() {
   echo -n $" - $*"

   if [[ "${NO_COLOR}" != "-no-color" ]]; then
      echo -en "\\033[120G"
      echo -en "\\033[1;31m"
   fi
   echo $" [FAILED]"
   if [[ "${NO_COLOR}" != "-no-color" ]]; then
      echo -en "\\033[0;39m"
   fi
   return 1
}

#=== FUNCTION ================================================================
# NAME: error_if_not_zero
# DESCRIPTION: Test if $1 is 0 otherwise, exit with response $1
#=============================================================================
function error_if_not_zero() {
   RC=$1
   shift
   if [ "${RC}" != "0" ]; then
      echo "   # Error detected $*"
      echo "   ###############################################################################"
      export HAS_ERROR=${RC}
      if [ -z "${CONTINUE}" -a "${CONTINUE}" != "-continue" ]; then
         exit ${RC}
      fi
   fi
}

#=== FUNCTION ================================================================
# NAME: exit_if_not_zero
# DESCRIPTION: Test if $1 is 0 otherwise, exit with response $1
#=============================================================================
function exit_if_not_zero() {
   error_if_not_zero $*
}

#=== FUNCTION ================================================================
# NAME: warning_if_not_zero
# DESCRIPTION: Test if $1 is 0 otherwise, set warning flag with response $1
#=============================================================================
function warning_if_not_zero() {
   RC=$1
   shift
   if [ "${RC}" != "0" ]; then
      echo "   ! Warning detected $*"
      echo "   !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
      export HAS_WARNING=${RC}
   fi
}

#=== FUNCTION ================================================================
# NAME: display_check_status
# DESCRIPTION: Displa test status based on variable
#=============================================================================
function display_check_status() {

   log "End of Checks. Status = "
   if [[ ! -z "${HAS_WARNING}" && "${HAS_WARNING}" != "0" ]]; then 
     log "- Warning detected while executing checks : Those don't prevent installation to be completed but they can explain why installation or application does not works as expected."
   else
     log "- No warning detected"
   fi

   if [[ ! -z "${HAS_ERROR}" && "${HAS_ERROR}" != "0" ]]; then 
     log "-  Error detected while executing checks. Unless -ignore-checks flag is on, those will block the installation process and prevent we move further until those are solved."
     if [ "${IGNORE_CHECKS}" == "-ignore-checks" ]; then 
       log "   - Erros are ignored as -ignore-checks flag is on but still, don't expect installation or application to works."
     else
         exit $CHECK_RETURN_CODE
     fi
   else
     log "- No error detected"
   fi
}

#=== FUNCTION ================================================================
# NAME: numerize_version
# DESCRIPTION: convert tools version in numbre we can compare.
#===============================================================================
function numerize_version()
{ 
   echo "$@" | sed "s/_.*//g" | gawk -F. '{ printf("%03d%03d%03d\n", $1,$2,$3); }'; 
}

################################################################################
#  SECTION : TESTING FUNCTION 
################################################################################

#=== FUNCTION ================================================================
# NAME: assert_zero
# DESCRIPTION: Check if $1 == 0 otherwise, display error message and exit with response code  1
#=============================================================================
function assert_zero()
{
   if [[ $1 -ne 0 ]]; then
      shift
      error "$*"
   fi
   return 0 
}

#=== FUNCTION ================================================================
# NAME: check_zero
# Test if parameter $1 is true
# Param 1 : parameter to check
# Param 2 and next : check label
#=============================================================================
function check_zero()
{
   CODE=$1
   shift
   CHECK_NAME=$*

   # Check input parameter
   if [ "${CODE}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$1 (CODE=${CODE}) is empty."
      return 3
   fi 

   
   if [ $CODE -ne 0 ];
   then
      failure ${CHECK_NAME}
      return 1
   else
      success ${CHECK_NAME}
      return 0
   fi
}

#=== FUNCTION ================================================================
# NAME: check_not_zero
# Test if parameter $1 is not equal to 0
# Param 1 : parameter to check
# Param 2 and next : check label
#=============================================================================
function check_not_zero()
{
   CODE=$1
   shift
   CHECK_NAME=$*

   # Check input parameter
   if [ "${CODE}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$1 (CODE=${CODE}) is empty."
      return 3
   fi 

   
   if [ $CODE -eq 0 ];
   then
      failure ${CHECK_NAME}
      return 1
   else
      success ${CHECK_NAME}
      return 0
   fi
}

#=== FUNCTION ================================================================
# NAME: check_condition
# Test if parameter $1 is true
# Param 1 : parameter to check
# Param 2 and next : check label
#=============================================================================
function check_condition()
{
   CONDITION=$1
   shift
   CHECK_NAME=$*

   # Check input parameter
   if [ "${CONDITION}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$1 (CONDITION=${CONDITION}) is empty."
      return 3
   fi 
   
   test $CONDITION 

   if [[ $? -ne 0 ]];
   then
      failure ${CHECK_NAME}
      return 1
   else
      success ${CHECK_NAME}
      return 0
   fi
}

#=== FUNCTION ================================================================
# NAME: check_version
# Test if $1 and $2 are same version
# Param 3 and next : check label
#=============================================================================
function check_version()
{
   VERSION=$1
   BASE_VERSION=$2
   shift
   shift
   CHECK_NAME=$*

   # Check input parameter
   if [ "${VERSION}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$1 (VERSION=${VERSION}) is empty."
      return 3
   fi 
   if [ "${BASE_VERSION}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$2 (BASE_VERSION=${BASE_VERSION}) is empty."
      return 3
   fi 
   
   if [[ "${VERSION}" == "${BASE_VERSION}*" ]];
   then
      failure ${CHECK_NAME}
      return 1
   else
      success ${CHECK_NAME}
      return 0
   fi
}

#=== FUNCTION ================================================================
# NAME: check_version
# Test if $1 >= $2 as version
# Param 3 and next : check label
#=============================================================================
function check_version_superior()
{
   VERSION=`numerize_version $1`
   BASE_VERSION=`numerize_version $2`
   shift
   shift
   CHECK_NAME=$*

   # Check input parameter
   if [ "${VERSION}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$1 (VERSION=${VERSION}) is empty."
      return 3
   fi 
   if [ "${BASE_VERSION}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$2 (BASE_VERSION=${BASE_VERSION}) is empty."
      return 3
   fi 
   
   if [[ $((10#$VERSION)) -lt $((10#$BASE_VERSION)) ]];
   then
      failure ${CHECK_NAME}
      return 1
   else
      success ${CHECK_NAME}
      return 0
   fi
}

#=== FUNCTION ================================================================
# NAME: check_current_user
# Test if $1 is current user
# Param 2 and next : check label
#=============================================================================
function check_current_user()
{
   USERNAME=$1
   CHECK_NAME="Current shell user is ${USERNAME}"

   # Check input parameter
   if [ "${USERNAME}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$1 (USERNAME=${USERNAME}) is empty."
      return 3
   fi 

   OUT=`whoami`
   if [ "${OUT}" != "${USERNAME}" ];
   then
      failure ${CHECK_NAME}
      log "Current shell user is not ${USER_NAME}"
      return 1
   else
      success ${CHECK_NAME}
      return 0
   fi
}

#=== FUNCTION ================================================================
# NAME: check_dir_RWX_rights_for_user
# Test if user $2 has RWX rigth on $1
# Param 3 and next : check label
#=============================================================================
function check_dir_RWX_rights_for_user()
{
   DIR=$1
   USERNAME=$2
   CHECK_NAME="${DIR} exists and is owned by ${USERNAME}"

   # Check input parameter
   if [ "${DIR}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$1 (DIR=${DIR}) is empty."
      return 3
   fi 
   
   # Check if DIR exists
   if [ ! -d "${DIR}" ];
   then
      failure ${CHECK_NAME}
      log "Error : Directory \$1 (DIR=${DIR}) does tno exists."
      return 1
   elif [ ! -r "${DIR}" ];
   then
      failure ${CHECK_NAME}
      log "Error : User ${USER_NAME} don't have read rights on directory \$1 (DIR=${DIR})."
      return 1
   elif [ ! -w "${DIR}" ];
   then
      failure ${CHECK_NAME}
      log "Error : User ${USER_NAME} don't have write rights on directory \$1 (DIR=${DIR})."
      return 1
   elif [ ! -x "${DIR}" ];
   then
      failure ${CHECK_NAME}
      log "Error : User ${USER_NAME} don't have execution rights on directory \$1 (DIR=${DIR})."
      return 1
   else
      success ${CHECK_NAME}
      return 0
   fi
}

#=== FUNCTION ================================================================
# NAME: check_command_in_path
# Test if command $1 is in PATH
# Param 2 and next : check label
#=============================================================================
function check_command_in_path()
{
   CMD=$1
   CHECK_NAME="${CMD} is reachable in PATH"

   # Check input parameter
   if [ "${CMD}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$1 (CMD=${CMD}) does not referecne a command."
      return 3
   fi 

   OUT=`type -p "${CMD}"`
   if [ "$OUT" == "" ];
   then
      failure ${CHECK_NAME}
      log "Command [${CMD}] is not accessible in PATH"
      return 1
   else
      success ${CHECK_NAME}
      return 0
   fi
}

