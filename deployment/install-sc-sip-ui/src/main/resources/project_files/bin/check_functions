#=== FUNCTION ================================================================
# NAME: check_command_is_ok
# Exec $* and check if its return code is null
#=============================================================================
function check_command_is_ok()
{
   CMD=$*
   CHECK_NAME="${CMD} can be executed without error"

   # Check input parameter
   if [ "${CMD}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$1 (CMD=${CMD}) does not referecne a command."
      return 3
   fi 

   ${CMD} &> /dev/null
   if [[ $? -ne 0 ]];
   then
      failure ${CHECK_NAME}
      log "Command [${CMD}] is executed with errors"
      return 1
   else
      success ${CHECK_NAME}
      return 0
   fi
}

#=== FUNCTION ================================================================
# NAME: check_runas_command_is_ok
# Exec sudo -u $1 a command and check if its return code is null
# Param 1 : user to runas
# Param < 1 : command
#=============================================================================
function check_runas_command_is_ok()
{
   CURRENT_USER=`whoami`
   USER=$1
   shift
   CMD="$*"
   CHECK_NAME="${CMD} can be executed as ${USER} without error"
   RC=0
   
   if [ "${CURRENT_USER}" == "${USER}" ]; then
      ${CMD} 2>&1 /dev/null
      RC=$?
   else
      sudo -u ${USER} -n ${CMD} >& /dev/null
      RC=$?
   fi 

   if [[ $RC -ne 0 ]];
   then
      failure ${CHECK_NAME}
      return 1
   else
      success ${CHECK_NAME}
      return 0
   fi
}

#=== FUNCTION ================================================================
# NAME: check_port_listening
# Check if port $1 is listening on sevrer
# Param 2 and next : check label
#=============================================================================
function check_port_listening()
{
   MAX_TIME=30
   PORT=$1
   TIMEOUT=$2
   CHECK_NAME="Launched Program listen on port [${PORT}]"

   # Check input parameter
   if [ "${PORT}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$1 (PORT=${PORT}) does not referecne a tcp port."
      return 3
   fi 

   # Check input parameter
   if [ "${TIMEOUT}" != "" ];
   then
      MAX_TIME=${TIMEOUT}
   fi 

   SUCCESS=0

   # wait max 30 second for port to listen
   COUNTER=0
   IS_STOP=0
   while [  $COUNTER -lt ${MAX_TIME} -a $IS_STOP -eq 0 ]; 
   do
      OUT=`/usr/sbin/ss -ntpl 2>&1 | grep ":${PORT} "`
      if [ "$OUT" == "" ];
      then
         SUCCESS=0
         IS_STOP=0
         sleep 1
      else
         SUCCESS=1
         IS_STOP=1
      fi
      let COUNTER=COUNTER+1 
   done

   if [ $SUCCESS -ne 1 ];
   then
      failure ${CHECK_NAME}
      return 1
   else
      success ${CHECK_NAME}
      return 0
   fi
}

#=== FUNCTION ================================================================
# NAME: check_http_get_return_something
# Check if url $1 return something
# Param 2 and next : check label
#=============================================================================
function check_http_get_return_something()
{
   URL=$1
   shift
   PARAM=$*
   CHECK_NAME="${URL} answer with a Http return code"

   # Check input parameter
   if [ "${URL}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$1 (URL=${URL}) is not provided."
      return 3
   fi 

   if [ "${RC}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$2 (RC=${RC}) is not provided."
      return 3
   fi 

   URL_RC=`wget -t 1 -T 60 -S -qO- ${PARAM} ${URL} 2>&1 | grep "HTTP/" | awk '{print $2}'`
   if [ "${URL_RC}" != "" ]; then
      success ${CHECK_NAME}
      CHECK_RC=0
   else
      failure ${CHECK_NAME}
      log "$URL return without any return code"
      CHECK_RC=${RC}
   fi
   return ${CHECK_RC}
}

#=== FUNCTION ================================================================
# NAME: check_http_get_return_code
# Check if url $1 answer with return code $2 
# Param 3 and next : HTTP parameters
#=============================================================================
function check_http_get_return_code()
{
   URL=$1
   RC=$2
   shift
   shift
   PARAM=$*
   CHECK_NAME="${URL} answer with ${RC} code"

   # Check input parameter
   if [ "${URL}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$1 (URL=${URL}) is not provided."
      return 3
   fi 

   if [ "${RC}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$2 (RC=${RC}) is not provided."
      return 3
   fi 

   URL_RC=`wget -t 1 -T 60 -S -qO- ${PARAM} ${URL} 2>&1 | grep "HTTP/" | awk '{print $2}'`
   if [ "${URL_RC}" == "${RC}" ]; then
      success ${CHECK_NAME}
      CHECK_RC=0
   else
      failure ${CHECK_NAME}
      log "$URL return with return code ${URL_RC} (!=${RC})"
      CHECK_RC=${RC}
   fi
   return ${CHECK_RC}
}

#=== FUNCTION ================================================================
# NAME: check_http_get_ok
# Check if url $1 answer with return code OK
# Param 2 and next : HTTP parameters
#=============================================================================
function check_http_get_ok()
{
   URL=$1
   shift
   PARAM=$*
   CHECK_NAME="${URL} is reached"

   # Check input parameter
   if [ "${URL}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$1 (URL=${URL}) is not provided."
      return 3
   fi 

   OUT=`wget -t 1 -T 60 -S -qO- ${PARAM} ${URL} 2>&1`
   RC=$?
   if [ ${RC} -eq 0 ]; then
      success ${CHECK_NAME}
      CHECK_RC=0
   elif [ ${RC} -eq 1 ]; then
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code 1 : Generic error code)"
      CHECK_RC=${RC}
   elif [ ${RC} -eq 2 ]; then
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code 2 : Parse error)"
      CHECK_RC=${RC}
   elif [ ${RC} -eq 3 ]; then
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code 3 : File I/O error)"
      CHECK_RC=${RC}
   elif [ ${RC} -eq 4 ]; then
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code 4 : Network failure)"
      CHECK_RC=${RC}
   elif [ ${RC} -eq 5 ]; then
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code 5 : SSL verification failure)"
      CHECK_RC=${RC}
   elif [ ${RC} -eq 6 ]; then
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code 6 : Username/password authentication failure)"
      CHECK_RC=${RC}
   elif [ ${RC} -eq 7 ]; then
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code 7 : Protocol errors)"
      CHECK_RC=${RC}
   elif [ ${RC} -eq 8 ]; then
      echo "DEBUG : wget --spider -S -qO- ${PARAM} ${URL}"
      wget -t 1 -T 60 --spider -S -qO- ${PARAM} ${URL} | sed "s/^/DEBUG: /g"
      ERROR_CODE=`wget -t 1 -T 60 --spider -S -qO- ${PARAM} ${URL} | grep "HTTP/" | awk '{print $2}'`
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code 8 : Server issued an error response ${ERROR_CODE})"
      CHECK_RC=${RC}
   else
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code ${RC})"
      CHECK_RC=${RC}
   fi
   return ${CHECK_RC}
}

#=== FUNCTION ================================================================
# NAME: check_http_post_json_ok
# Check if http post on url $1 with Json $2 answer with return code OK
#=============================================================================
function check_http_post_json_ok()
{
   URL=$1
   JSON=$2
   CHECK_NAME="${URL} POST is reached"

   # Check input parameter
   if [ "${URL}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$1 (URL=${URL}) is not provided."
      return 3
   fi 
   if [ "${JSON}" == "" ];
   then
      failure ${CHECK_NAME}
      log "Error : Parameter \$2 (JSON=${JSON}) is not provided."
      return 3
   fi 

   OUT=`wget -t 1 -T 60 -S -q --header="Content-Type: application/json" --post-data "${JSON}" ${URL} 2>&1`
   RC=$?
   if [ ${RC} -eq 0 ]; then
      success ${CHECK_NAME}
      CHECK_RC=0
   elif [ ${RC} -eq 1 ]; then
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code 1 : Generic error code)"
      CHECK_RC=${RC}
   elif [ ${RC} -eq 2 ]; then
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code 2 : Parse error)"
      CHECK_RC=${RC}
   elif [ ${RC} -eq 3 ]; then
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code 3 : File I/O error)"
      CHECK_RC=${RC}
   elif [ ${RC} -eq 4 ]; then
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code 4 : Network failure)"
      CHECK_RC=${RC}
   elif [ ${RC} -eq 5 ]; then
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code 5 : SSL verification failure)"
      CHECK_RC=${RC}
   elif [ ${RC} -eq 6 ]; then
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code 6 : Username/password authentication failure)"
      CHECK_RC=${RC}
   elif [ ${RC} -eq 7 ]; then
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code 7 : Protocol errors)"
      CHECK_RC=${RC}
   elif [ ${RC} -eq 8 ]; then
      echo "DEBUG : wget --spider -S -qO- ${PARAM} ${URL}"
      wget -t 1 -T 60 --spider -S -qO- ${PARAM} ${URL} | sed "s/^/DEBUG: /g"
      ERROR_CODE= `wget -t 1 -T 60 --spider -S -qO- ${PARAM} ${URL} | grep "HTTP/" | awk '{print $2}'`
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code 8 : Server issued an error response ${ERROR_CODE})"
      CHECK_RC=${RC}
   else
      failure ${CHECK_NAME}
      log "Impossible to access $URL (wget error code ${RC})"
      CHECK_RC=${RC}
   fi
   return ${CHECK_RC}
}

#=== FUNCTION ================================================================
# NAME: check_mysqldb_is_on
# Test if DB is accessible
# Param 1 : DB Host
# Param 2 : DB Port
# Param 3 : DB Username
# Param 4 : DB Password
# Param 5 : Schema
# Param 6 (facultative) : -nolog -> Don't display any logs
#=============================================================================
function check_mysqldb_is_on()
{
   TEST_DB_HOST=$1
   TEST_DB_PORT=$2
   TEST_DB_USER=$3
   TEST_DB_PASSWORD=$4
   CHECK_NAME="mysql://${TEST_DB_USER}@${TEST_DB_HOST}:${TEST_DB_PORT}/${TEST_DB_SCHEMA} is on"

   # Check input parameter
   if [ -z "${TEST_DB_HOST}" ]; then
      failure ${CHECK_NAME}
      log "Function Parameter \$1 (DB_HOST) is not defined. "
      return 3
   fi
   if [ -z "${TEST_DB_PORT}" ]; then
      failure ${CHECK_NAME}
      log  "Function Parameter \$2 (DB_PORT) is not defined. "
      return 3
   fi
   if [ -z "${TEST_DB_USER}" ]; then
      failure ${CHECK_NAME}
      log  "Function Parameter \3 (DB_USER) is not defined. "
      return 3
   fi
   if [ -z "${TEST_DB_PASSWORD}" ]; then
      failure ${CHECK_NAME}
      log  "Function Parameter \$4 (DB_PASSWORD) is not defined. "
      return 3
   fi
   
   OUT=`echo "status;" | mysql --host ${TEST_DB_HOST} --port=${TEST_DB_PORT} --user=${TEST_DB_USER} --password=${TEST_DB_PASSWORD} 2>&1`
   RC=$?
   if [ ${RC} -ne 0 ]; then
      failure ${CHECK_NAME}
      log "MySQL DB [${TEST_DB_HOST}:${TEST_DB_PORT}] is not accessible (${OUT})"
      return 1
   else
      success ${CHECK_NAME}
      return 0
   fi   
}

#=== FUNCTION ================================================================
# NAME: check_mysqldb_schema
# Test if DB is accessible and have specific schema 
# Param 1 : DB Host
# Param 2 : DB Port
# Param 3 : DB Username
# Param 4 : DB Password
# Param 5 : Schema
# Param 6 (facultative) : -nolog -> Don't display any logs
#=============================================================================
function check_mysqldb_schema()
{
   TEST_DB_HOST=$1
   TEST_DB_PORT=$2
   TEST_DB_USER=$3
   TEST_DB_PASSWORD=$4
   TEST_DB_SCHEMA=$5
   CHECK_NAME="mysql://${TEST_DB_USER}@${TEST_DB_HOST}:${TEST_DB_PORT}/${TEST_DB_SCHEMA} is reachable from server"

   # Check input parameter
   if [ -z "${TEST_DB_HOST}" ]; then
      failure ${CHECK_NAME}
      log "Function Parameter \$1 (DB_HOST) is not defined. "
      return 3
   fi
   if [ -z "${TEST_DB_PORT}" ]; then
      failure ${CHECK_NAME}
      log  "Function Parameter \$2 (DB_PORT) is not defined. "
      return 3
   fi
   if [ -z "${TEST_DB_USER}" ]; then
      failure ${CHECK_NAME}
      log  "Function Parameter \3 (DB_USER) is not defined. "
      return 3
   fi
   if [ -z "${TEST_DB_PASSWORD}" ]; then
      failure ${CHECK_NAME}
      log  "Function Parameter \$4 (DB_PASSWORD) is not defined. "
      return 3
   fi
   if [ -z "${TEST_DB_SCHEMA}" ]; then
      failure ${CHECK_NAME}
      log  "Function Parameter \$4 (DB_SCHEMA) is not defined. "
      return 3
   fi
   
   OUT=`mysqlshow --host ${TEST_DB_HOST} --port=${TEST_DB_PORT} --user=${TEST_DB_USER} --password=${TEST_DB_PASSWORD} 2>&1`
   RC=$?
   if [ ${RC} -ne 0 ]; then
      failure ${CHECK_NAME}
      log "MySQL DB [${TEST_DB_HOST}:${TEST_DB_PORT}] is not accessible (${OUT})"
      return 1
   fi   
   
   NB=`echo $OUT | grep "${TEST_DB_SCHEMA}"`
   if [ "$NB" == "" ]; then
      failure ${CHECK_NAME}
      log "MySQL DB [${TEST_DB_HOST}:${TEST_DB_PORT}] doesn't have any schema ${TEST_DB_SCHEMA}"
      return 1
   else
      success ${CHECK_NAME}
      return 0
   fi
}
